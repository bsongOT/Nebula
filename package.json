{
  "name": "nebula",
  "version": "1.0.0",
  "description": "",
  "main": "backend/electron/electron.js",
  "private": true,
  "scripts": {
    "test": "webpack serve",
    "compile": "pushd backend/electron && tsc && popd",
    "start": "npm run compile && electron . && tsc --build --clean",
    "dev": "npm-run-all start test",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64"
  },
  "keywords": [],
  "author": "Songgot",
  "license": "ISC",
  "devDependencies": {
    "@types/p5": "^1.7.0",
    "css-loader": "^6.8.1",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "html-webpack-plugin": "^5.5.3",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.4",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lucide": "^0.475.0",
    "lucide-static": "^0.473.0",
    "npm-run-all": "^4.1.5",
    "p5": "^1.7.0",
    "pixi.js": "^8.3.2",
    "simple-git": "^3.27.0",
    "ts-node": "^10.9.2"
  },
  "build": {
    "productName": "Nebula",
    "appId": "com.editor.nebula",
    "directories": {
      "output": "build/${platform}/${arch}"
    },
    "win": {
      "target": ["zip"],
      "icon": "logo.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "logo.icns"
    }
  }
}
